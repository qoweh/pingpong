PINGPONG_WEB_PORT=8079
PINGPONG_POLICY_MODEL_PATH=rl/artifacts/pmk_cf_self_rally_v25/pmk_cf_self_rally_v25_model.zip
PINGPONG_POLICY_DETERMINISTIC=true
PINGPONG_LIVE_SEED=251

# Only needed if the vendored simulation source is moved.
# Defaults to backend/vendor/pingpong_rl2.
# PINGPONG_RL_SOURCE_ROOT=backend/vendor/pingpong_rl2

# Only needed when recompiling frontend/public/assets/mujoco/pingpong_scene.mjb.
# Defaults to rl/assets.
# PINGPONG_MUJOCO_SOURCE_ROOT=rl/assets

# Only needed if the simulation service should use a different MJCF scene.
# Defaults to rl/assets/scene.xml.
# PINGPONG_MUJOCO_SCENE_PATH=rl/assets/scene.xml
